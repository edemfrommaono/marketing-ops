datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  STRATEGIST
  CONTENT_PLANNER
  DESIGNER
  PHOTOGRAPHER
  VIDEOGRAPHER
  SOCIAL_MEDIA_MANAGER
  CLIENT
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum Platform {
  INSTAGRAM
  FACEBOOK
  LINKEDIN
  TIKTOK
  YOUTUBE
  X
}

enum ContentType {
  POST
  STORY
  REEL
  VIDEO
  ARTICLE
  INFOGRAPHIC
  CAROUSEL
}

enum ContentFormat {
  IMAGE
  VIDEO
  TEXT
  MIXED
}

enum ContentStatus {
  DRAFT
  IN_PRODUCTION
  INTERNAL_REVIEW
  CLIENT_REVIEW
  APPROVED
  REVISION_REQUIRED
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum ProductionTeam {
  DESIGN
  PHOTOGRAPHY
  VIDEO
  COPYWRITING
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum AssetType {
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
  RAW
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION_REQUIRED
}

enum NotificationType {
  TASK_ASSIGNED
  DEADLINE_APPROACHING
  CONTENT_APPROVED
  REVISION_REQUIRED
  CONTENT_PUBLISHED
  RISK_FLAGGED
  CAMPAIGN_STARTED
}

enum ReminderType {
  J_MINUS_7
  J_MINUS_3
  J_MINUS_1
  J_0
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─────────────────────────────────────────────
// AUTH MODELS (NextAuth)
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String?   @unique
  emailVerified        DateTime?
  image                String?
  role                 UserRole  @default(DESIGNER)
  hashedPassword       String?
  onboardingCompleted  Boolean   @default(false)

  accounts     Account[]
  sessions     Session[]
  integrations IntegrationConnection[]

  // Editorial relations
  assignedTasks    ProductionTask[] @relation("TaskAssignee")
  createdCampaigns Campaign[]       @relation("CampaignCreator")
  approvals        Approval[]       @relation("ApprovalReviewer")
  publications     Publication[]    @relation("ContentPublisher")
  notifications    Notification[]
  auditLogs        AuditLog[]
  uploadedAssets   Asset[]          @relation("AssetUploader")
  reportedRisks    Risk[]           @relation("RiskReporter")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model IntegrationConnection {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  providerUrl  String?
  accessToken  String?  @db.Text
  refreshToken String?  @db.Text
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

// ─────────────────────────────────────────────
// EDITORIAL MODELS
// ─────────────────────────────────────────────

/// Business client — distinct from auth User
model Client {
  id          String  @id @default(cuid())
  name        String
  company     String
  email       String  @unique
  contactName String?
  logoUrl     String?
  isActive    Boolean @default(true)

  campaigns    Campaign[]
  portalTokens ClientPortalToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Campaign — top-level editorial unit
model Campaign {
  id         String         @id @default(cuid())
  name       String
  objective  String         @db.Text
  status     CampaignStatus @default(DRAFT)
  startDate  DateTime
  endDate    DateTime
  kpiTargets Json?          // { reach: 100000, engagement: 5, ctr: 2 }
  platforms  Platform[]

  clientId    String
  client      Client @relation(fields: [clientId], references: [id])
  createdById String
  createdBy   User   @relation("CampaignCreator", fields: [createdById], references: [id])

  calendarEntries CalendarEntry[]
  risks           Risk[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Calendar entry — one scheduled slot in the editorial calendar
model CalendarEntry {
  id              String      @id @default(cuid())
  publicationDate DateTime
  platform        Platform
  contentType     ContentType
  theme           String
  notes           String?     @db.Text

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  contents Content[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Content item — the central production entity
model Content {
  id            String        @id @default(cuid())
  title         String
  format        ContentFormat
  assignedTeam  ProductionTeam
  deadline      DateTime
  status        ContentStatus @default(DRAFT)
  briefUrl      String?       // Link to brief document
  briefNotes    String?       @db.Text

  calendarEntryId String
  calendarEntry   CalendarEntry @relation(fields: [calendarEntryId], references: [id], onDelete: Cascade)

  assets      Asset[]
  approvals   Approval[]
  variants    ContentVariant[]
  tasks       ProductionTask[]
  publication Publication?
  performance Performance?
  reminders   Reminder[]
  auditLogs   AuditLog[]   @relation("ContentAuditLogs")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Platform-specific variant of a content item
/// e.g. same campaign post adapted for Instagram vs LinkedIn
model ContentVariant {
  id            String   @id @default(cuid())
  platform      Platform
  adaptedTitle  String?
  adaptedNotes  String?  @db.Text

  contentId String
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  assets Asset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contentId, platform])
}

/// Production task — assigned to a team member, with dependencies
model ProductionTask {
  id       String     @id @default(cuid())
  title    String
  type     ProductionTeam
  status   TaskStatus @default(PENDING)
  deadline DateTime?
  notes    String?    @db.Text

  contentId    String
  content      Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  assignedToId String?
  assignedTo   User?   @relation("TaskAssignee", fields: [assignedToId], references: [id])

  // Self-referencing dependency (this task blocks others)
  dependsOnId String?
  dependsOn   ProductionTask?  @relation("TaskDependency", fields: [dependsOnId], references: [id])
  blockedBy   ProductionTask[] @relation("TaskDependency")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Asset — uploaded file with versioning support
model Asset {
  id        String    @id @default(cuid())
  fileUrl   String
  fileName  String
  fileSize  Int?      // bytes
  mimeType  String?
  version   Int       @default(1)
  assetType AssetType
  isActive  Boolean   @default(true) // false = superseded by newer version

  contentId String
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  variantId String?
  variant   ContentVariant? @relation(fields: [variantId], references: [id])

  uploadedById String?
  uploadedBy   User?   @relation("AssetUploader", fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())
}

/// Approval — tracks internal then client sign-off
model Approval {
  id             String         @id @default(cuid())
  internalStatus ApprovalStatus @default(PENDING)
  clientStatus   ApprovalStatus @default(PENDING)
  internalNote   String?        @db.Text
  clientNote     String?        @db.Text
  reviewedAt     DateTime?

  contentId    String
  content      Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  reviewedById String?
  reviewedBy   User?   @relation("ApprovalReviewer", fields: [reviewedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Publication — record of a content item going live
model Publication {
  id          String   @id @default(cuid())
  platform    Platform
  publishedAt DateTime @default(now())
  externalId  String?  // Platform post ID (e.g. Instagram post ID)
  url         String?  // Direct link to published post

  contentId    String  @unique
  content      Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  publishedById String?
  publishedBy   User?  @relation("ContentPublisher", fields: [publishedById], references: [id])

  performance Performance?
}

/// Performance — metrics collected after publication
model Performance {
  id          String   @id @default(cuid())
  impressions Int      @default(0)
  reach       Int      @default(0)
  engagement  Int      @default(0)  // likes + comments + shares
  clicks      Int      @default(0)
  conversions Int      @default(0)
  ctr         Float?   // click-through rate %
  collectedAt DateTime @default(now())

  contentId     String      @unique
  content       Content     @relation(fields: [contentId], references: [id], onDelete: Cascade)
  publicationId String?     @unique
  publication   Publication? @relation(fields: [publicationId], references: [id])
}

/// Notification — in-app alerts for users
model Notification {
  id      String           @id @default(cuid())
  type    NotificationType
  title   String
  message String           @db.Text
  isRead  Boolean          @default(false)

  // Optional links to related entities
  relatedCampaignId String?
  relatedContentId  String?
  relatedTaskId     String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

/// Reminder — scheduled deadline alerts (J-7, J-3, J-1, J-0)
model Reminder {
  id           String       @id @default(cuid())
  reminderType ReminderType
  scheduledAt  DateTime
  isSent       Boolean      @default(false)
  sentAt       DateTime?

  contentId String
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

/// AuditLog — full change history for compliance
model AuditLog {
  id         String  @id @default(cuid())
  action     String  // e.g. "STATUS_CHANGED", "ASSET_UPLOADED", "APPROVAL_GRANTED"
  entityType String  // e.g. "Content", "Approval", "Asset"
  entityId   String
  prevValue  Json?
  newValue   Json?

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  // Optional content link for quick filtering
  contentId String?
  content   Content? @relation("ContentAuditLogs", fields: [contentId], references: [id])

  createdAt DateTime @default(now())
}

/// Client portal token — secure tokenised access for clients
model ClientPortalToken {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  expiresAt DateTime?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

/// Risk — flags for late content, missing assets, client non-response
model Risk {
  id          String    @id @default(cuid())
  title       String
  description String    @db.Text
  level       RiskLevel
  isResolved  Boolean   @default(false)
  resolvedAt  DateTime?
  mitigation  String?   @db.Text

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // Optional link to a specific content item
  contentId String?

  reportedById String?
  reportedBy   User?   @relation("RiskReporter", fields: [reportedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
